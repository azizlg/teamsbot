# ============================================================
# Intelligent Multilingual Meeting Agent — Environment Variables
# Copy this file to .env and fill in all values.
# ============================================================

# --- Environment ---
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=text                  # text | json (json in production)

# --- Microsoft Azure Bot (free registration required for Teams) ---
MICROSOFT_APP_ID=fec00466-c8a1-453d-9bc5-033b9212771b
MICROSOFT_APP_PASSWORD=FYk8Q~aCabxJXZcDRpmPxi8yRfhfooUichkQpbcL
MICROSOFT_APP_TENANT_ID=95ea510f-498a-4089-af48-be9d9b9a2ccc

# --- Groq LLM API (free: https://console.groq.com) ---
GROQ_API_KEY=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
GROQ_MODEL=llama-3.3-70b-versatile

# --- MinIO Object Storage (runs locally via Docker) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=meeting-audio-chunks
MINIO_SECURE=false

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://meeting_agent:changeme@localhost:5432/meeting_agent

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_STREAM_NAME=audio-chunks
REDIS_CONSUMER_GROUP=whisper-workers
REDIS_MAX_RETRIES=3

# --- Azure Communication Services (free tier — enables audio streaming from Teams) ---
# Create at portal.azure.com → Communication Services → Keys → Connection String
# IMPORTANT: Add the real value as a Secret in HF Space settings, not here.
AZURE_COMMUNICATION_CONNECTION_STRING=endpoint=https://myagentlatest.unitedstates.communication.azure.com/;accesskey=58WrZzypNJDYhidwaxgNKn6pb5uTR7d65XO9p71nJsEcOvCaMsC6JQQJ99CBACULyCp5Tn7pAAAAAZCShtdW

# --- pyannote (free: https://huggingface.co) ---
PYANNOTE_AUTH_TOKEN=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

# --- Whisper ---
WHISPER_MODEL_SIZE=large-v3       # tiny | base | small | medium | large-v3
WHISPER_DEVICE=auto               # auto | cpu | cuda
WHISPER_COMPUTE_TYPE=float16      # float16 | int8 | float32
WHISPER_REALTIME_CHUNK_SECONDS=10 # seconds of audio per real-time chunk

# --- Audio Settings ---
AUDIO_SAMPLE_RATE=16000           # Hz
AUDIO_CHANNELS=1                  # mono
AUDIO_CHUNK_DURATION_SECONDS=300  # 5 minutes (for batch processing)
AUDIO_SILENCE_THRESHOLD_DB=-40    # dB level for silence detection
AUDIO_SILENCE_MIN_DURATION_MS=500 # minimum silence duration in ms
AZURE_SPEECH_KEY =FFFoQXXkyo0W2a6DMvreuVuJPL1TgLM7ehsYfN8Csyt0VogQKIlQJQQJ99CCACYeBjFXJ3w3AAAYACOGc1Hp
AZURE_SPEECH_REGION = eastus
CERT_THUMBPRINT=9DF94ED45B981B0553B172618F2E8B6927B4E3FE
 
# --- Tunnel (Cloudflare / ngrok) ---
TUNNEL_URL=https://samuel-specialist-whom-nsw.trycloudflare.com
